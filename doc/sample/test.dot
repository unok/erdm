
digraph g {
  node [shape=box,style=rounded,height=0.08,fontname="Noto Sans Mono CJK JP"];


  users [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">site user master/users</font></td></tr><tr><td align="left">member id/id  bigserial (UNN)</td><td>P</td><td></td></tr><tr><td align="left">nickname/nick_name  varchar(128) (NN)</td><td></td><td></td></tr><tr><td align="left">site password/password  varchar(128) </td><td></td><td></td></tr><tr><td align="left">profile/profile  text </td><td></td><td></td></tr></table>>];

  articles [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">article/articles</font></td></tr><tr><td align="left">article id/id  bigserial (UNN)</td><td>P</td><td></td></tr><tr><td align="left">article title/title  varchar(256) (NN)</td><td></td><td></td></tr><tr><td align="left">article text/contents  text (NN)</td><td></td><td></td></tr><tr><td align="left">creator/owner_user_id  bigint (NN)</td><td>F</td><td></td></tr></table>>];

  tags [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">tag master/tags</font></td></tr><tr><td align="left">tag id/id  bigserial (UNN)</td><td>P</td><td></td></tr><tr><td align="left">tag name/name  varchar(256) (UNN)</td><td></td><td></td></tr></table>>];

  article_tags [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">article tag relation table/article_tags</font></td></tr><tr><td align="left">id  bigserial (UNN)</td><td>P</td><td></td></tr><tr><td align="left">article_id  bigint (NN)</td><td>F</td><td></td></tr><tr><td align="left">tag_id  bigint (NN)</td><td>F</td><td></td></tr></table>>];




  edge [
    arrowhead = "none"
    headlabel = "0..*"
    taillabel = "1"
  ]
  articles -> users


  edge [
    arrowhead = "none"
    headlabel = "0..*"
    taillabel = "1"
  ]
  article_tags -> users


  edge [
    arrowhead = "none"
    headlabel = "0..*"
    taillabel = "1"
  ]
  article_tags -> tags

}
