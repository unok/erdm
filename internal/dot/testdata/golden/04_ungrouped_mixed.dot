digraph g {
  rankdir=LR;
  splines=polyline;
  nodesep=1.0;
  ranksep=2.0;
  concentrate=false;
  node [shape=plaintext,height=0.08,margin="0",fontname="Noto Sans Mono CJK JP"];

  subgraph cluster_auth {
    label="auth";


  users [label = <<table border="1" cellborder="0" cellspacing="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">users</font></td></tr><tr><td port="id__w"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e"></td></tr><tr><td port="name__w"></td><td align="left">name  varchar(64) (NN)</td><td></td><td></td><td port="name__e"></td></tr></table>>];
  }


  guests [label = <<table border="1" cellborder="0" cellspacing="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">guests</font></td></tr><tr><td port="id__w"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e"></td></tr><tr><td port="token__w"></td><td align="left">token  varchar(32) (UNN)</td><td></td><td></td><td port="token__e"></td></tr></table>>];


}
