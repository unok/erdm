digraph g {
  rankdir=LR;
  splines=ortho;
  nodesep=0.8;
  ranksep=1.2;
  concentrate=false;
  node [shape=box,style=rounded,height=0.08,fontname="Noto Sans Mono CJK JP"];

  subgraph cluster_auth {
    label="auth";


  users [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">users</font></td></tr><tr><td port="id__w" width="1" fixedsize="true"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e" width="1" fixedsize="true"></td></tr><tr><td port="name__w" width="1" fixedsize="true"></td><td align="left">name  varchar(64) (NN)</td><td></td><td></td><td port="name__e" width="1" fixedsize="true"></td></tr></table>>];
  }


  guests [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">guests</font></td></tr><tr><td port="id__w" width="1" fixedsize="true"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e" width="1" fixedsize="true"></td></tr><tr><td port="token__w" width="1" fixedsize="true"></td><td align="left">token  varchar(32) (UNN)</td><td></td><td></td><td port="token__e" width="1" fixedsize="true"></td></tr></table>>];


}
