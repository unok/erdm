digraph g {
  rankdir=LR;
  splines=ortho;
  nodesep=0.8;
  ranksep=1.2;
  concentrate=false;
  node [shape=box,style=rounded,height=0.08,fontname="Noto Sans Mono CJK JP"];


  customers [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">顧客/customers</font></td></tr><tr><td align="left">id  int (NN)</td><td>P</td><td></td></tr><tr><td align="left">name  varchar(64) (NN)</td><td></td><td></td></tr></table>>];

  orders [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">orders</font></td></tr><tr><td align="left">id  int (NN)</td><td>P</td><td></td></tr><tr><td align="left">customer_id  int (NN)</td><td>F</td><td></td></tr><tr><td align="left">status  varchar(16) (NN)</td><td></td><td></td></tr></table>>];

  order_items [label = <<table border="0" cellborder="0" cellpadding="0">
    <tr><td colspan="2"><font face="Ricty-Bold">order_items</font></td></tr><tr><td align="left">order_id  int (NN)</td><td>PF</td><td></td></tr><tr><td align="left">line_no  int (NN)</td><td>P</td><td></td></tr><tr><td align="left">qty  int (NN)</td><td></td><td></td></tr></table>>];



  edge [
    arrowhead = "none"
    headlabel = "0..*"
    taillabel = "1"
  ]
  customers -> orders


  edge [
    arrowhead = "none"
    headlabel = "1..*"
    taillabel = "1"
  ]
  orders -> order_items

}
