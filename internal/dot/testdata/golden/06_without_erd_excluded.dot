digraph g {
  rankdir=LR;
  splines=ortho;
  nodesep=0.8;
  ranksep=1.2;
  concentrate=false;
  node [shape=plaintext,height=0.08,margin="0",fontname="Noto Sans Mono CJK JP"];


  users [label = <<table border="1" cellborder="0" cellspacing="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">users</font></td></tr><tr><td port="id__w" width="1" fixedsize="true"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e" width="1" fixedsize="true"></td></tr><tr><td port="name__w" width="1" fixedsize="true"></td><td align="left">name  varchar(64) (NN)</td><td></td><td></td><td port="name__e" width="1" fixedsize="true"></td></tr></table>>];

  legacy [label = <<table border="1" cellborder="0" cellspacing="0" cellpadding="0">
    <tr><td colspan="5"><font face="Ricty-Bold">legacy</font></td></tr><tr><td port="id__w" width="1" fixedsize="true"></td><td align="left">id  int (NN)</td><td>P</td><td></td><td port="id__e" width="1" fixedsize="true"></td></tr><tr><td port="note__w" width="1" fixedsize="true"></td><td align="left">note  text (NN)</td><td></td><td></td><td port="note__e" width="1" fixedsize="true"></td></tr></table>>];


}
